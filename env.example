# EROS static configuration (§6.10). Copy to .env in backend/ or export.
EROS_DSN=postgresql://eros:eros@127.0.0.1:5432/eros
EROS_DATA_DIR=~/.eros/data
# Gate 4 posture: 'shadow' until M7 < 2% on the Gold Set, then 'blocking'.
EROS_GATE4_MODE=shadow
EROS_OLLAMA_BASE_URL=http://127.0.0.1:11434
# FR18: set true to require the explicit degraded-mode choice at run start.
EROS_REQUIRE_LOCAL_GENERATION=false
# External escalation (FR5): OFF by default. ZDR flags are hard admission
# requirements — set them only after confirming Zero Data Retention with
# your provider agreement.
EROS_EXTERNAL_ENABLED=false
EROS_ANTHROPIC_ZDR_CONFIRMED=false
EROS_OPENAI_ZDR_CONFIRMED=false
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# BING_API_KEY=
EROS_BUDGET_CEILING_USD=50.00
